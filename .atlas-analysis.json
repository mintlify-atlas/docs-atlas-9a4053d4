  "keyFeatures": [
    "Custom MMO networking protocol with efficient binary serialization",
    "Content scripting system for NPCs and interactive objects",
    "Binary data formats optimized for game assets (textures, tiles, maps, NPCs, items)",
    "Built-in GUI map editor for chunk-based world editing",
    "Client-server architecture with Ebiten-powered game client",
    "Data packer CLI for converting manifests to optimized binary formats",
    "Player persistence with SQLite database and migrations",
    "Real-time multiplayer with tick-based game loop",
    "Inventory and skill system with XP progression"
  ],
  "publicApiSurface": [
    "grpg/data-go/gbuf - Binary buffer reading/writing utilities",
    "grpg/data-go/grpgtex - Texture format with JPEGXL compression",
    "grpg/data-go/grpgtile - Tile data format",
    "grpg/data-go/grpgobj - Object data format",
    "grpg/data-go/grpgnpc - NPC data format",
    "grpg/data-go/grpgitem - Item data format",
    "grpg/data-go/grpgmap - Map/chunk data format",
    "grpgpack tex - Pack textures from manifest",
    "grpgpack tile - Pack tiles from manifest",
    "grpgpack obj - Pack objects from manifest",
    "grpgpack npc - Pack NPCs from manifest",
    "grpgpack item - Pack items from manifest",
    "server/scripts.OnObjInteract - Register object interaction handler",
    "server/scripts.OnNpcTalk - Register NPC dialogue handler",
    "server/scripts.SpawnNpc - Spawn NPC at coordinates"
